# このファイルをコピーして terraform.tfvars を作成し、実際の値を設定すること。
# terraform.tfvars には実際のリソース名・ARN・アカウントIDが含まれるため、
# リポジトリにはコミットしない（.gitignore で除外されている）。

aws_region    = "ap-northeast-1"
github_org    = "your-github-org"
github_repo   = "auto-blog"
github_branch = "main"

s3_bucket_name = "your-actual-bucket-name"
s3_bucket_arn  = "arn:aws:s3:::your-actual-bucket-name"

cloudfront_distribution_id  = "E1234567890ABC"
cloudfront_distribution_arn = "arn:aws:cloudfront::123456789012:distribution/E1234567890ABC"
